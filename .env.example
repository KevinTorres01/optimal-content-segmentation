# ─── Proveedor LLM principal ───────────────────────────────────────────────────
# Groq — plataforma de inferencia rápida, tier gratuito (accesible desde Cuba)
# Obtener en: https://console.groq.com/
GROQ_API_KEY=

# ─── Fallback online ────────────────────────────────────────────────────────────
# Mistral AI — se usa si Groq falla o agota su cuota (empresa francesa)
# Obtener en: https://console.mistral.ai/
MISTRAL_API_KEY=

# ─── Control de fallback ───────────────────────────────────────────────────────
# Si Groq falla, usar Mistral automáticamente (requiere MISTRAL_API_KEY)
LLM_FALLBACK_ENABLED=true
# Timeout en segundos antes de hacer fallback (cubre throttle + reintentos)
LLM_TIMEOUT_SECONDS=30

# ─── Rate limiting (tier gratuito) ─────────────────────────────────────────────
# Segundos mínimos entre llamadas online. Los tiers gratuitos limitan el ritmo,
# así que espaciar evita errores 429 y obtiene scores reales en vez de degradados.
# Pon 0 para desactivar (tier de pago, mucho más rápido).
LLM_MIN_REQUEST_INTERVAL_SECONDS=1.5
