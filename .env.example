# ─── Proveedores LLM online (accesibles desde Cuba) ───────────────────────────
# Al menos uno es requerido para usar evaluación LLM en experimentos.

# Mistral AI — primario recomendado (empresa francesa)
# Obtener en: https://console.mistral.ai/
MISTRAL_API_KEY=

# DeepSeek — alternativo muy capaz (empresa china, muy barato)
# Obtener en: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ─── Modo local: Ollama (fallback sin internet) ────────────────────────────────
# Instalar Ollama: https://ollama.ai/
# Descargar modelo: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Control de fallback ───────────────────────────────────────────────────────
# Si el proveedor online falla, usar Ollama automáticamente
LLM_FALLBACK_ENABLED=true
# Timeout en segundos antes de hacer fallback (Cuba puede tener latencia alta)
LLM_TIMEOUT_SECONDS=15
